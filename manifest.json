{
  "manifest_version": 3,
  "name": "Block YouTube Shorts Sections",
  "description": "Hides YouTube Shorts shelves and Shorts cards on YouTube Home and Subscriptions.",
  "version": "1.2.0",
  "icons": {
    "48": "icons/blockshorts.svg",
    "96": "icons/blockshorts.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "blockshorts@stablum.github",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}


